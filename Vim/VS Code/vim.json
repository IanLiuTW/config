      ],
      "commands": [
        ":tabo"
      ]
    },
    {
      "before": [
        "<Leader>",
        "t",
        "q"
      ],
      "commands": [
        ":tabc"
      ]
    },
    {
      "before": [
        "<Leader>",
        "/"
      ],
      "commands": [
        ":noh"
      ]
    },
    {
      "before": [
        "<Leader>",
        "o"
      ],
      "after": [
        "o",
        "<esc>"
      ],
    },
    {
      "before": [
        "<Leader>",
        "O"
      ],
      "after": [
        "O",
        "<esc>"
      ],
    },
    // Vim - Harpoon keybindings
