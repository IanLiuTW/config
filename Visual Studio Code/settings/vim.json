{
    "vim.easymotion": true,
    "vim.handleKeys": {
        "<C-f>": false
    },
    "vim.hlsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "after": [
                "<esc>"
            ],
            "before": [
                "j",
                "k"
            ]
        }
    ],
    "vim.leader": "<space>",
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<Leader>",
                "j"
            ],
            "after": [
                "5",
                "j"
            ]
        },
        {
            "before": [
                "<Leader>",
                "k"
            ],
            "after": [
                "5",
                "k"
            ]
        },
        {
            "after": [
                "y",
                "$"
            ],
            "before": [
                "Y"
            ]
        },
        {
            "before": [
                "<Leader>",
                "t",
                "t"
            ],
            "commands": [
                ":tabnew"
            ]
        },
        {
            "before": [
                "<Leader>",
                "t",
                "n"
            ],
            "commands": [
                ":tabnext"
            ]
        },
        {
            "before": [
                "<Leader>",
                "t",
                "p"
            ],
            "commands": [
                ":tabprev"
            ]
        },
        {
            "before": [
                "<Leader>",
                "t",
                "o"
            ],
            "commands": [
                ":tabo"
            ]
        },
        {
            "before": [
                "<Leader>",
                "/"
            ],
            "commands": [
                ":noh"
            ]
        },
        {
            "after": [
                "o",
                "<esc>"
            ],
            "before": [
                "<Leader>",
                "o"
            ]
        },
        {
            "after": [
                "O",
                "<esc>"
            ],
            "before": [
                "<Leader>",
                "O"
            ]
        },
        // Vim - Harpoon keybindings
        {
            "before": [
                "<leader>",
                "a"
            ],
            "commands": [
                "vscode-harpoon.addEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "p",
            ],
            "commands": [
                "vscode-harpoon.editorQuickPick"
            ]
        },
        {
            "before": [
                "<leader>",
                "P",
            ],
            "commands": [
                "vscode-harpoon.gotoPreviousHarpoonEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "e",
                "e"
            ],
            "commands": [
                "vscode-harpoon.editEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "e",
                "1"
            ],
            "commands": [
                "vscode-harpoon.addEditor1"
            ]
        },
        {
            "before": [
                "<leader>",
                "e",
                "2"
            ],
            "commands": [
                "vscode-harpoon.addEditor2"
            ]
        },
        {
            "before": [
                "<leader>",
                "e",
                "3"
            ],
            "commands": [
                "vscode-harpoon.addEditor3"
            ]
        },
        {
            "before": [
                "<leader>",
                "e",
                "4"
            ],
            "commands": [
                "vscode-harpoon.addEditor4"
            ]
        },
        {
            "before": [
                "<leader>",
